{
  "info": {
    "name": "Ecourse API",
    "description": "Koleksi lengkap API Ecourse.\n\n🌐 PUBLIC — semua orang bisa akses (guest & login)\n🔐 PRIVATE — harus login, gunakan Bearer token\n\nBase URL: http://localhost:8080/api\n\nCara pakai:\n1. Jalankan 'Auth > Login' → token tersimpan otomatis\n2. Semua request private langsung pakai token tersebut",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
