              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Judul Update", "type": "text" },
                { "key": "description", "value": "Deskripsi update", "type": "text" },
                { "key": "link", "value": "https://github.com/username/repo", "type": "text" },
                { "key": "cover", "type": "file", "description": "Optional - ganti cover" }
              ]
            }
          }
        },
