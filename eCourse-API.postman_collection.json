            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Judul Showcase", "type": "text" },
                { "key": "description", "value": "Deskripsi proyek", "type": "text" },
                { "key": "link", "value": "https://github.com/username/repo", "type": "text" },
                { "key": "cover", "type": "file", "description": "Image max 2MB" },
                { "key": "course_id", "value": "", "type": "text", "description": "Optional - ID kursus terkait" }
              ]
            }
